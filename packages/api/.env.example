DATABASE_URL="postgresql://financeapp:financeapp@localhost:5432/financeapp_dev"
REDIS_URL="redis://localhost:6379"

# Must be at least 32 chars in production
JWT_SECRET="dev-secret-key-change-in-production-32+"

# Port for the Express API server
PORT=3001

# CORS — comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000"

# Anthropic (for AI categorisation worker)
ANTHROPIC_API_KEY=""

# Environment
NODE_ENV="development"
