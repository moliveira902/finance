# dependencies
node_modules/
.pnp
.pnp.js

# Next.js build output
apps/web/.next/
apps/web/out/

# production builds
dist/
build/
# Exception: shared-types dist/ must be committed so Vercel can resolve
# the package without a build step (pnpm workspace symlink + main: dist/index.js)
!packages/shared-types/dist/

# environment variables — never commit secrets
.env
.env.local
.env.*.local

# Claude Code local config
.claude/

# OS / editor noise
.DS_Store
Thumbs.db
*.log
.vscode/settings.json

# Turbo cache
.turbo/

# pnpm lock (keep if using pnpm workspaces)
# pnpm-lock.yaml

# package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules
