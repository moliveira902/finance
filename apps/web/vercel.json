{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "pnpm install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/health-score",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/inactivity",
      "schedule": "0 13 * * *"
    }
  ]
}
